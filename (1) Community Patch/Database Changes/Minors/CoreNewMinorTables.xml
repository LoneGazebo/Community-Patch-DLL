<?xml version="1.0" encoding="utf-8"?>
<!-- All these tables are x100 -->
<GameData>
	<!-- Determines what player yields a city-state type will give when friendly, in what era -->
	<Table name="MinorCivilizationTraits_FriendYieldBonuses">
		<Column name="MinorCivTraitType" type="text" reference="MinorCivTraits(Type)" notnull="true"/>
        <Column name="EraType" type="text" reference="Eras(Type)" notnull="true"/>
		<Column name="YieldType" type="integer" notnull="true"/>
		<Column name="Yield" type="integer" notnull="true"/>
	</Table>
	<!-- Determines what player yields a city-state type will give when allied, in what era -->
	<Table name="MinorCivilizationTraits_AllyYieldBonuses">
		<Column name="MinorCivTraitType" type="text" reference="MinorCivTraits(Type)" notnull="true"/>
        <Column name="EraType" type="text" reference="Eras(Type)" notnull="true"/>
		<Column name="YieldType" type="integer" notnull="true"/>
		<Column name="Yield" type="integer" notnull="true"/>
	</Table>
	<!-- Determines what city yields a city-state type will give when friendly, in what era, and whether they're only given to the Capital -->
	<Table name="MinorCivilizationTraits_FriendCityYieldBonuses">
		<Column name="MinorCivTraitType" type="text" reference="MinorCivTraits(Type)" notnull="true"/>
        <Column name="EraType" type="text" reference="Eras(Type)" notnull="true"/>
		<Column name="YieldType" type="integer" notnull="true"/>
		<Column name="Yield" type="integer" notnull="true"/>
		<Column name="CapitalOnly" type="boolean" notnull="true" default="false"/>
	</Table>
	<!-- Determines what city yields a city-state type will give when allied, in what era, and whether they're only given to the Capital -->
	<Table name="MinorCivilizationTraits_AllyCityYieldBonuses">
		<Column name="MinorCivTraitType" type="text" reference="MinorCivTraits(Type)" notnull="true"/>
        <Column name="EraType" type="text" reference="Eras(Type)" notnull="true"/>
		<Column name="YieldType" type="integer" notnull="true"/>
		<Column name="Yield" type="integer" notnull="true"/>
		<Column name="CapitalOnly" type="boolean" notnull="true" default="false"/>
	</Table>
	<!-- Determines the relative probabilities of city-state quests based on trait, personality, and era (game era for global quests, player era for personal quests) -->
	<!-- Weight is only applied if the player meets the requirements to be given that quest -->
	<!-- Setting weight to 0 prevents the quest from being given, this replaces the QUEST_DISABLED GameDefines for each quest -->
	<Table name="MinorCivilizations_QuestWeights">
		<Column name="MinorCivTraitType" type="text" reference="MinorCivTraits(Type)" notnull="true"/>
		<Column name="MinorCivPersonalityType" type="text" reference="MinorCivPersonalityTypes(Type)" notnull="true"/>
		<Column name="EraType" type="text" reference="Eras(Type)" notnull="true"/>
		<Column name="QuestType" type="text" reference="SmallAwards(Type)" notnull="true"/>
		<Column name="Weight" type="integer" notnull="true" default="0"/>
	</Table>
</GameData>