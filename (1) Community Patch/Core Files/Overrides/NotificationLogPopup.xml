<?xml version="1.0" encoding="utf-8"?>
<Context Font="TwCenMT14" FontStyle="Base" Color="Beige" Color1="Black" >

	<Instance Name="LogInstance">
		<Button ID="LogButton" Size="920,32">
			<Label 
				Anchor="R,T" 
				Offset="8,12"
				Font="TwCenMT18" ColorSet="Beige_Black_Alpha"
				ID="LogTurnLabel" />

			<Stack Anchor="L,T" Padding="6" ID="LogTextStack">
				<!-- Spacer -->
				<Grid Size="1,4" />

				<Label
					Anchor="L,T" Offset="8,2" WrapWidth="828"
					Font="TwCenMT18" ColorSet="Beige_Black_Alpha" FontStyle="Shadow"
					ID="LogTextLabel" />

				<!-- Spacer -->
				<Grid Size="1,2" /> 

				<!-- Separator -->
				<Image Anchor="C,B" Texture="bar900x2.dds" Size="980,1" />
			</Stack>

			<ShowOnMouseOver>
				<AlphaAnim Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1" ID="LogTextHoverAnim">
					<Grid Size="932,32" Offset="-6,0" Style="Grid9FrameTurnsHL" ID="LogTextHoverElem" />
				</AlphaAnim>
			</ShowOnMouseOver>
		</Button>
	</Instance>

	<Instance Name="OptInstance">
		<Button Anchor="L,C" Size="900,32" ID="OptButton">
			<Stack StackGrowth="Right" Padding="12" ID="OptStack">
				<CheckBox Anchor="L,C" ID="OptCheckbox" />
				<Label Anchor="L,C" ColorSet="Beige_Black_Alpha" Font="TwCenMT18" FontStyle="Shadow" ID="OptTextLabel"/>				
			</Stack>

			<Label Anchor="R,C" Offset="12,0" ColorSet="Beige_Black_Alpha" Font="TwCenMT16" FontStyle="Shadow" ID="OptKindLabel"/>

			<Image Anchor="L,B" Texture="BlueBar500x3.dds" Size="900,1"/>

			<ShowOnMouseOver>
				<AlphaAnim Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1">
					<Grid Size="900,32" Style="Grid9FrameTurnsHL"/>
				</AlphaAnim>
			</ShowOnMouseOver>
		</Button>
	</Instance>

	<Instance Name="OptKindInstance">
		<RadioButton TextAnchor="R,C" TextAnchorSide="O,O" RadioGroup="Kind" ID="OptKindButton" />
	</Instance>

	<Box Style="BGBlock_ClearTopBar" />
	
	<Grid Anchor="C,C" Size="960,658" Offset="0,36" Padding="0,0" 
		Style="Grid9Frame27_EmptyFrame" ConsumeMouse="0">

		<!-- Upper Treatment -->
		<Image Anchor="C,T" AnchorSide="I,O" Size="256,64" Offset="0,-10" Texture="assets\UI\Art\Icons\Top512IconTrim.dds">
			<Image Anchor="C,T" Size="64,64" ID="CivIconBg" />
			<Image Anchor="C,C" Size="48,48" ID="CivIconShadow" />
			<Image Anchor="C,C" Size="48,48" ID="CivIcon" />
		</Image>

		<!-- View Switch -->
		<Container Anchor="C,T" Size="950,32" Offset="0,4">
			<Button Anchor="L,C" Size="475,28" String="TXT_KEY_POP_NOTIFICATION_LOG" ID="ShowLogsView">
				<ShowOnMouseOver>
					<AlphaAnim Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1">
						<Grid Size="475,28" Style="Grid9FrameTurnsHL"/>
					</AlphaAnim>
				</ShowOnMouseOver>

				<Grid Size="475,28" Style="Grid9FrameTurns" ID="LogsViewDecor" />
			</Button>

			<Button Anchor="R,C" Size="475,28" String="TXT_KEY_NOTIFICATION_SETTINGS_TITLE" ID="ShowOptsView">
				<ShowOnMouseOver>
					<AlphaAnim Pause="0" Cycle="Bounce" Speed="1" AlphaStart="2" AlphaEnd="1">
						<Grid Size="475,28" Style="Grid9FrameTurnsHL" />
					</AlphaAnim>
				</ShowOnMouseOver>

				<Grid Size="475,28" Style="Grid9FrameTurns" ID="OptsViewDecor"/>
			</Button>
			
			<Image Anchor="C,B" Offset="0,-2" Size="955,2" Texture="HorizontalTrim.dds" />
		</Container>
		
		<!-- Logs View -->
		<Container Size="952,550" Offset="4,41" ID="LogsView">
			<ScrollPanel Anchor="C,T" Size="952,550" Vertical="1" ID="LogsScroll" AutoSize="1" >
				<UpButton Anchor="R,T" Offset="4,4" Style="ScrollBarUp" />
				<ScrollBar Anchor="R,C" Offset="4,0" Style="VertSlider" Length="508" />
				<DownButton Anchor="R,B" Offset="4,4" Style="ScrollBarDown" />
				<Stack Anchor="L,T" Offset="6,0" StackGrowth="Up" ID="LogsStack" />
			</ScrollPanel>
		</Container>

		<!-- Opts View -->
		<Container Size="952,550" Offset="4,41" ID="OptsView">
			<Stack StackGrowth="Down" Padding="6">
				<Container Anchor="C,T" Size="950,28" Color="White">
					<Stack Anchor="L,C" Offset="12,0" Padding="136" StackGrowth="Right" ID="OptKindsStack" />
					<Image Anchor="C,T" Offset="0,30" Size="955,2" Texture="HorizontalTrim.dds" />
				</Container>

				<ScrollPanel Anchor="C,T" Size="952,518"  Vertical="1" ID="OptsScroll">
					<UpButton Anchor="R,T" Offset="4,4" Style="ScrollBarUp" />
					<ScrollBar Anchor="R,C" Offset="4,0" Style="VertSlider" Length="478" />
					<DownButton Anchor="R,B" Offset="4,6" Style="ScrollBarDown" />
					<Stack Anchor="L,T" Offset="16,0" StackGrowth="Bottom" ID="OptsStack" />
				</ScrollPanel>
			</Stack>
		</Container>

		<!-- Bottom Panel -->
		<Container Anchor="C,B" Size="952,32" Offset="0,32">
			<!-- Line -->
			<Image Anchor="C,T" Size="955,2" Texture="HorizontalTrim.dds" />

			<!-- Left Stack -->
			<Stack Anchor="L,B" Padding="16,0" Offset="16,-16" StackGrowth="Right">
				<GridButton Anchor="L,B" Style="SmallButton" Size="148,32" Offset="16,0" ID="CloseButton"  >
					<Label Anchor="C,C" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" String="TXT_KEY_CLOSE"/>
				</GridButton>
			</Stack>

			<!-- Right Stack -->
			<Stack Anchor="R,B" Padding="16,0" Offset="16,-16" StackGrowth="Left" >
				<GridButton Style="SmallButton" Size="148,32" ID="DisableCurrOptsButton">
					<Label Anchor="C,C" Font="TwCenMT18" ColorSet="Beige_Black_Alpha" 
						String="TXT_KEY_NOTIFICATION_SETTINGS_TURN_OFF_ALL_BUTTON"/>
				</GridButton>
				<GridButton Style="SmallButton" Size="148,32" ID="EnableCurrOptsButton">
					<Label Anchor="C,C" Font="TwCenMT18" ColorSet="Beige_Black_Alpha"
						String="TXT_KEY_NOTIFICATION_SETTINGS_TURN_ON_ALL_BUTTON"/>
				</GridButton>
			</Stack>
		</Container>

	</Grid>
</Context>